// Create a new mount
mount(
    source, target, filesystemtype,
    mountflags = 0,
    data
);

// Create a mount that suppresses set-ID and file-capability privilege gains
mount(
    source, target, filesystemtype,
    mountflags = MS_NOSUID,
    data
);

// Move the existing mount point
mount(
    source, target, filesystemtype,
    mountflags = MS_MOVE,
    data
);

// Create a bind mount
mount(
    source, target, filesystemtype,
    mountflags = MS_BIND | MS_REC,
    data
);
